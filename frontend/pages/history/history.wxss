.history-container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.history-header {
  background: white;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.history-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.edit-btn, .clear-btn {
  font-size: 28rpx;
  background: none;
  padding: 0;
  margin: 0;
  border: none;
  color: #667eea;
}

.edit-btn::after, .clear-btn::after {
  border: none;
}

.clear-btn {
  color: #e64340;
}

.history-list {
  flex: 1;
  padding: 20rpx;
}

.history-item {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  transition: all 0.2s;
}

.history-item:active {
  transform: scale(0.98);
}

.item-left {
  flex: 1;
}

.item-word {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.item-time {
  font-size: 22rpx;
  color: #999;
}

.item-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.item-confidence {
  font-size: 30rpx;
  color: #667eea;
  font-weight: bold;
}

.delete-btn {
  font-size: 40rpx;
  padding: 10rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border-radius: 60rpx;
  padding: 20rpx 60rpx;
  font-size: 30rpx;
  border: none;
}