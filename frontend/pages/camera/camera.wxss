/* 相机预览区 */
.camera-view {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #000;
}

.camera {
  width: 100%;
  height: 100%;
}

/* 图片预览区 */
.preview-view {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-image {
  width: 100%;
  height: 100%;
}

/* 底部按钮组 - 左右布局 */
.bottom-button-group {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 80rpx;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(10px);
  gap: 80rpx;
}

/* 拍照按钮容器 */
.shutter-wrapper {
  flex-shrink: 0;
}

/* 拍照按钮样式（大圆形） */
.shutter-btn {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}

.shutter-btn:active {
  transform: scale(0.95);
}

.shutter-inner {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: white;
}

/* 相册按钮容器 */
.album-wrapper {
  flex-shrink: 0;
}

/* 相册按钮样式（胶囊形） */
.album-btn {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 60rpx;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 40rpx;
  font-size: 28rpx;
  color: #333;
  border: none;
  display: flex;
  align-items: center;
  gap: 10rpx;
  transition: opacity 0.2s;
}

.album-btn:active {
  opacity: 0.8;
}

/* 去掉微信按钮默认边框 */
.album-btn::after {
  border: none;
}

/* 预览模式按钮组 */
.preview-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 30rpx;
  padding: 30rpx 40rpx;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(10px);
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn::after {
  border: none;
}

.reset-btn {
  background: rgba(255, 255, 255, 0.9);
  color: #333;
}

.confirm-btn {
  background: #07c160;
  color: white;
}

/* 加载遮罩 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  color: white;
  font-size: 28rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 适配全面屏底部安全区 */
.bottom-button-group,
.preview-actions {
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}